Name:           libthreadpool-devel
Version:        @VERSION@
Release:        1%{?dist}
Summary:        header-only C++ thread pool library
License:        Apache-2.0
URL:            https://github.com/lwhttpdorg/threadpool
Source0:        libthreadpool-%{version}.tar.gz
BuildArch:      noarch

BuildRequires:  cmake >= 3.11
BuildRequires:  gcc-c++

%description
A C++ thread pool implementation modeled after Java's ThreadPoolExecutor.

%prep
%autosetup -n libthreadpool-%{version} -p1

%build
%cmake -DCMAKE_INSTALL_LIBDIR=lib
%cmake_build

%install
%cmake_install

%files
%license LICENSE
%doc README.md
%{_includedir}/*.hpp
%{_prefix}/lib/cmake/ThreadPool/

%changelog
* Fri May 16 2026 Alex Sandro <dev@manjunos.com> - 0.1.0-1
- Initial release
